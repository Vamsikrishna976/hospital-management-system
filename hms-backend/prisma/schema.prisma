// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id String @id @default(uuid())

  patientNumber String @unique

  fullName String
  mobile   String @unique

  alternateMobile String?

  email String?

  address String

  city    String?
  state   String?
  pincode String?

  age    Int
  gender String

  bloodGroup String?

  occupation String?

  emergencyContact String?

  opRecords OPRecord[]

  labOrders LabOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OPRecord {
  id String @id @default(uuid())

  opNumber String @unique

  patientId String

  patient Patient @relation(fields: [patientId], references: [id])

  bloodPressure String?

  sugarLevel Float?

  weight Float?

  height Float?

  bmi Float?

  temperature Float?

  pulseRate Int?

  spo2 Int?

  complaint Complaint?

  appointment Appointment[]

  billing Billing?

  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  RECEPTIONIST
  MANAGEMENT
  DOCTOR
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  phone    String?
  password String
  role     Role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Complaint {
  id String @id @default(uuid())

  opRecordId String @unique

  chiefComplaint String
  symptoms       String

  duration String?

  previousMedication String?

  clinicalNotes String?

  createdAt DateTime @default(now())

  opRecord OPRecord @relation(fields: [opRecordId], references: [id])
}

model Doctor {
  id              String  @id @default(uuid())
  doctorCode      String  @unique
  fullName        String
  specialization  String
  qualification   String?
  mobile          String
  email           String?
  consultationFee Float   @default(500)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]

  labOrders LabOrder[]
}

enum AppointmentStatus {
  ASSIGNED
  COMPLETED
  CANCELLED
}

model Appointment {
  id String @id @default(uuid())

  appointmentNo String @unique

  opRecordId String
  doctorId   String

  appointmentDate DateTime?
  appointmentTime String?

  status AppointmentStatus @default(ASSIGNED)

  assignedAt DateTime @default(now())

  opRecord OPRecord @relation(fields: [opRecordId], references: [id])

  doctor Doctor @relation(fields: [doctorId], references: [id])

  prescription Prescription?
}

model Prescription {
  id String @id @default(uuid())

  appointmentId String @unique

  diagnosis String

  notes String?

  followUpDate DateTime?

  dispensed Boolean @default(false)

  createdAt DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  medicines Medicine[]
}

model Medicine {
  id String @id @default(uuid())

  prescriptionId String

  medicineName String

  dosage String

  frequency String

  duration String

  prescription Prescription @relation(fields: [prescriptionId], references: [id])
}

enum PaymentStatus {
  PENDING
  PAID
}

model Billing {
  id String @id @default(uuid())

  billNumber String? @unique

  opRecordId String @unique

  consultationFee Float
  medicineFee     Float
  labFee          Float
  otherFee        Float
  totalAmount     Float

  paymentStatus String @default("PENDING")

  createdAt DateTime @default(now())

  opRecord OPRecord @relation(fields: [opRecordId], references: [id])
}

model AuditLog {
  id String @id @default(uuid())

  action String

  userEmail String

  createdAt DateTime @default(now())
}

model MedicineInventory {
  id String @id @default(uuid())

  medicineCode String @unique
  medicineName String

  category String?

  stockQuantity Int @default(0)

  unitPrice Float

  expiryDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  billItems PharmacyBillItem[]
}

model PharmacyAuditLog {
  id String @id @default(uuid())

  medicineName String

  action String

  quantity Int

  createdAt DateTime @default(now())
}

model PharmacyBill {
  id String @id @default(uuid())

  billNumber String @unique

  patientName String

  totalAmount Float

  createdAt DateTime @default(now())

  items PharmacyBillItem[]
}

model PharmacyBillItem {
  id String @id @default(uuid())

  billId     String
  medicineId String

  quantity Int

  unitPrice Float

  totalPrice Float

  bill PharmacyBill @relation(fields: [billId], references: [id])

  medicine MedicineInventory @relation(fields: [medicineId], references: [id])
}

model LabTest {
  id          String  @id @default(uuid())
  testCode    String  @unique
  testName    String
  category    String
  price       Float
  description String?

  createdAt DateTime @default(now())

  orderItems LabOrderItem[]
}

model LabOrder {
  id String @id @default(uuid())

  patientId String
  doctorId  String

  status LabOrderStatus @default(PENDING)

  createdAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])

  items LabOrderItem[]
}

model LabOrderItem {
  id String @id @default(uuid())

  orderId   String
  labTestId String

  result         String?
  unit           String?
  referenceRange String?
  remarks        String?

  completedAt DateTime?

  order   LabOrder @relation(fields: [orderId], references: [id])
  labTest LabTest  @relation(fields: [labTestId], references: [id])
}

enum LabOrderStatus {
  PENDING
  SAMPLE_COLLECTED
  PROCESSING
  COMPLETED
}
