generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id               String        @id @default(uuid())
  patientNumber    String        @unique
  fullName         String
  mobile           String        @unique
  age              Int
  gender           String
  address          String
  createdAt        DateTime      @default(now())
  alternateMobile  String?
  bloodGroup       String?
  city             String?
  email            String?
  emergencyContact String?
  occupation       String?
  pincode          String?
  state            String?
  updatedAt        DateTime      @updatedAt
  labOrders        LabOrder[]
  opRecords        OPRecord[]
  ipAdmissions     IPAdmission[]
}

model OPRecord {
  id            String        @id @default(uuid())
  opNumber      String        @unique
  patientId     String
  bloodPressure String?
  sugarLevel    Float?
  weight        Float?
  height        Float?
  bmi           Float?
  temperature   Float?
  pulseRate     Int?
  spo2          Int?
  createdAt     DateTime      @default(now())
  appointment   Appointment[]
  billing       Billing?
  complaint     Complaint?
  patient       Patient       @relation(fields: [patientId], references: [id])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Complaint {
  id                 String   @id @default(uuid())
  opRecordId         String   @unique
  chiefComplaint     String
  symptoms           String
  duration           String?
  previousMedication String?
  clinicalNotes      String?
  createdAt          DateTime @default(now())
  opRecord           OPRecord @relation(fields: [opRecordId], references: [id])
}

model Doctor {
  id              String        @id @default(uuid())
  qualification   String?
  specialization  String
  consultationFee Float         @default(500)
  createdAt       DateTime      @default(now())
  doctorCode      String        @unique
  email           String?
  fullName        String
  mobile          String
  updatedAt       DateTime      @updatedAt
  appointments    Appointment[]
  labOrders       LabOrder[]
}

model Appointment {
  id              String            @id @default(uuid())
  appointmentNo   String            @unique
  opRecordId      String
  doctorId        String
  assignedAt      DateTime          @default(now())
  status          AppointmentStatus @default(ASSIGNED)
  appointmentDate DateTime?
  appointmentTime String?
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  opRecord        OPRecord          @relation(fields: [opRecordId], references: [id])
  prescription    Prescription?
}

model Prescription {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  diagnosis     String
  notes         String?
  followUpDate  DateTime?
  createdAt     DateTime    @default(now())
  dispensed     Boolean     @default(false)
  medicines     Medicine[]
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
}

model Medicine {
  id             String       @id @default(uuid())
  prescriptionId String
  medicineName   String
  dosage         String
  frequency      String
  duration       String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
}

model Billing {
  id              String   @id @default(uuid())
  opRecordId      String   @unique
  consultationFee Float
  medicineFee     Float
  labFee          Float
  otherFee        Float
  totalAmount     Float
  createdAt       DateTime @default(now())
  billNumber      String?  @unique
  paymentStatus   String   @default("PENDING")
  opRecord        OPRecord @relation(fields: [opRecordId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userEmail String
  createdAt DateTime @default(now())
}

model MedicineInventory {
  id            String             @id @default(uuid())
  medicineCode  String             @unique
  medicineName  String
  category      String?
  stockQuantity Int                @default(0)
  unitPrice     Float
  expiryDate    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  billItems     PharmacyBillItem[]
}

model PharmacyAuditLog {
  id           String   @id @default(uuid())
  medicineName String
  action       String
  quantity     Int
  createdAt    DateTime @default(now())
}

model PharmacyBill {
  id            String             @id @default(uuid())
  billNumber    String             @unique
  patientName   String
  totalAmount   Float
  createdAt     DateTime           @default(now())
  cashier       String?
  discount      Float              @default(0)
  dueAmount     Float              @default(0)
  gstAmount     Float              @default(0)
  paidAmount    Float              @default(0)
  paymentStatus String             @default("PAID")
  pharmacist    String?
  subtotal      Float              @default(0)
  items         PharmacyBillItem[]
}

model PharmacyBillItem {
  id          String            @id @default(uuid())
  billId      String
  medicineId  String
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  batchNumber String?
  gst         Float             @default(0)
  bill        PharmacyBill      @relation(fields: [billId], references: [id])
  medicine    MedicineInventory @relation(fields: [medicineId], references: [id])
}

model LabTest {
  id          String         @id @default(uuid())
  testCode    String         @unique
  testName    String
  category    String
  price       Float
  description String?
  createdAt   DateTime       @default(now())
  orderItems  LabOrderItem[]
}

model LabOrder {
  id        String         @id @default(uuid())
  patientId String
  doctorId  String
  status    LabOrderStatus @default(PENDING)
  createdAt DateTime       @default(now())
  doctor    Doctor         @relation(fields: [doctorId], references: [id])
  patient   Patient        @relation(fields: [patientId], references: [id])
  items     LabOrderItem[]
}

model LabOrderItem {
  id             String    @id @default(uuid())
  orderId        String
  labTestId      String
  result         String?
  unit           String?
  referenceRange String?
  remarks        String?
  completedAt    DateTime?
  labTest        LabTest   @relation(fields: [labTestId], references: [id])
  order          LabOrder  @relation(fields: [orderId], references: [id])
}

enum Role {
  ADMIN
  RECEPTIONIST
  MANAGEMENT
  DOCTOR
}

enum AppointmentStatus {
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum LabOrderStatus {
  PENDING
  SAMPLE_COLLECTED
  PROCESSING
  COMPLETED
}

model IPAdmission {
  id String @id @default(uuid())

  admissionNo String @unique

  patientId String

  roomNumber String
  ward       String
  bedNumber  String

  admittedDate  DateTime  @default(now())
  dischargeDate DateTime?

  status String @default("ADMITTED")

  patient Patient @relation(fields: [patientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
